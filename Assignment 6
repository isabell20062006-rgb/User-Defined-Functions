/*
Function Name: printHeader
Purpose: Prints a formatted text banner line at the top of the program.
Parameters:courseTitle - a string containing the text banner message.
Return Value: N/A
*/
void printHeader(string courseTitle) {
    cout << "========================================" << endl;
    cout << "  " << courseTitle << "  " << endl;
    cout << "========================================" << endl << endl;
}

/*
Function Name: displayResult
Purpose: Prints a decriptor lable and dollar amount in 1 line.
Parameters: label - text identifying what the number represents.
value - the actual double number to display.
Return Value: N/A
*/
void displayResult(string label, double value) {
    cout << label << ": " << fixed << setprecision(2) << value << endl;
}

/*
Function Name: mathSummary
Purpose: Calculates square root, power, ceiling, floor, and inverted absolute values.
Parameters:x - a double value used as the mathematical input.
Return Value:  N/A
*/
void mathSummary(double x) {
    double squareRoot = sqrt(x);
    double powerOfThree = pow(x, 3);
    double ceilingVal = ceil(x);
    double floorVal = floor(x);
    double absValue = abs(x * -1);

    cout << "--- Math Summary for (x = " << x << ") ---" << endl;
    cout << "  Square root of x: " << squareRoot << endl;
    cout << "  x raised to power of 3: " << powerOfThree << endl;
    cout << "  Ceiling of x: " << ceilingVal << endl;
    cout << "  Floor of x: " << floorVal << endl;
    cout << "  Absolute value of (x * -1): " << absValue << endl;
}

/*
Function Name: calcTax
Purpose: Calculates the tax total based on earnings and rates.
Parameters: income - total raw gross earnings amount.
rate - tax scaling multiplier in decimal format.
Return Value: double - the computed tax bill total.
*/
double calcTax(double income, double rate) {
    return income * rate;
}

/*
Function Name: convertTime
Purpose: Splits raw seconds into whole minutes and remainder seconds
Parameters: totalSeconds - total input duration 
minutes - placeholder to save calculated minute
seconds - placeholder to save remaining seconds
Return Value: N/A
*/
void convertTime(int totalSeconds, int &minutes, int &seconds) {
    minutes = totalSeconds / 60;
    seconds = totalSeconds % 60;
}

/*
Function Name: countCalls
Purpose: Maintains a count of how many times this routine was run.
Parameters: N/A
Return Value: N/A
*/
void countCalls() {
    static int callCount = 0; 
    callCount++; 
    cout << "countCalls has been called " << callCount << " time(s)." << endl;
}

/*
Function Name: displayBox 
Purpose: Draws a perfect square hollow box pattern to the screen.
Parameters: width - the dimension size of the square sides.
Return Value: N/A
*/
void displayBox(int width) {
    displayBox(width, width); 
}

/*
Function Name: displayBox 
Purpose: Draws a hollow rectangular block matrix using star characters.
Parameters:  width - total stars long on horizontal rows.
height - total stars stacked on vertical columns.
Return Value: N/A
*/
void displayBox(int width, int height) {
    if (width <= 0 || height <= 0) {
        cout << "Invalid box dimensions." << endl;
        return;
    }
    for (int row = 1; row <= height; row++) {
        for (int col = 1; col <= width; col++) {
            if (row == 1 || row == height || col == 1 || col == width) {
                cout << "*";
            } else {
                cout << " "; 
            }
        }
        cout << endl;
    }
}
/*
Function Name: calcShipping
Purpose: Calculates cargo logistics charges based on load weights and fees.
Parameters: weight - system mass in pounds.
ratePerPound - flat charge rate per pound units.
baseFee - flat mandatory minimum operational toll.
Return Value:  double
*/
double calcShipping(double weight, double ratePerPound, double baseFee) {
    return baseFee + (weight * ratePerPound);
}